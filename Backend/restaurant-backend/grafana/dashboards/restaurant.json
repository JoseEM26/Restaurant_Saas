{
  "title": "Restaurant Backend - Overview",
  "uid": "restaurant-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (uri)",
        "legendFormat": "{{ uri }}",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 2,
      "title": "HTTP Response Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le, uri))",
        "legendFormat": "p95 {{ uri }}",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 3,
      "title": "JVM Heap Memory",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "targets": [{
        "expr": "jvm_memory_used_bytes{area=\"heap\"} / jvm_memory_max_bytes{area=\"heap\"} * 100",
        "legendFormat": "Heap %",
        "datasource": "Prometheus"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "max": 100, "unit": "percent",
        "thresholds": { "steps": [
          { "color": "green", "value": 0 },
          { "color": "yellow", "value": 70 },
          { "color": "red", "value": 85 }
        ]}
      }}
    },
    {
      "id": 4,
      "title": "Active DB Connections",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "targets": [{
        "expr": "hikaricp_connections_active",
        "legendFormat": "{{ pool }}",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 5,
      "title": "Resilience4j Circuit Breaker State",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "targets": [{
        "expr": "resilience4j_circuitbreaker_state",
        "legendFormat": "{{ name }} - {{ state }}",
        "datasource": "Prometheus"
      }]
    }
  ]
}
